# ── Существующий TenderBot (парсер + анализ) ─────────────────
BOT_TOKEN=токен_старого_бота_от_BotFather
ANTHROPIC_API_KEY=ключ_от_ProxyAPI
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
CLAUDE_MODEL_TRIAGE=claude-haiku-4-5
CLAUDE_MODEL_FINAL=claude-sonnet-4-6
ALLOWED_CHAT_IDS=твой_chat_id

# ── Portal (Mini App + новый бот) ────────────────────────────
PORTAL_BOT_TOKEN=токен_нового_бота_@tender1212bot
ADMIN_TELEGRAM_IDS=твой_telegram_id   # сразу получает роль admin без заявки

# URL портала — сначала Cloudflare Tunnel, потом заменишь на домен
# Пример: PORTAL_BASE_URL=https://abc-xyz.trycloudflare.com
PORTAL_BASE_URL=https://ЗАМЕНИ_НА_TUNNEL_URL

PORTAL_WEBHOOK_SECRET=придумай_случайную_строку_символов  # например: xK9mP2qRvL7
PORTAL_PORT=8000

# ── Общая БД (используется обоими сервисами) ─────────────────
DB_PATH=./tenderbot.db
